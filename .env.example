# 服务配置
APP_NAME=材料协同办理系统
APP_HOST=0.0.0.0
APP_PORT=5009
SECRET_KEY=please-change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 数据库（默认 SQLite，切换 PostgreSQL/Kingbase 时改 DATABASE_URL）
# SQLite:
DATABASE_URL=sqlite:///./data/collab.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql://user:password@host:5432/collab_review
# Kingbase 示例:
# DATABASE_URL=postgresql://user:password@host:54321/collab_review

# 默认管理员（首次启动自动创建，密码哈希存储）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_DISPLAY_NAME=系统管理员

# 是否创建演示账号 handler1 / leader_a / leader_b（密码 Demo@123456）
# 生产环境务必保持 false；本地联调可设为 true
SEED_DEMO_USERS=false

# 文件上传目录
UPLOAD_DIR=./uploads

# 调试模式（生产环境请设为 false）
DEBUG=false

# ---------- 认证模式 ----------
# local  仅本系统账号
# oa     仅 OA 账号密码（身份由 OA 验证）
# mixed  优先 OA；OA 不可用时仅允许本地管理员登录维护
AUTH_MODE=local

# OA 适配（仅写占位，勿提交真实地址以外的敏感信息）
OA_BASE_URL=http://your-oa-host.example
OA_LOGIN_PATH=/hportal/j_security_check
OA_PROFILE_PATH=/hportal/view/GetModuleTree.do
OA_LOGIN_TIMEOUT_SECONDS=8
OA_DEFAULT_ROLE=viewer
OA_VERIFY_TLS=false
# 部分环境登录前需探测用户编号，默认 false
OA_PRECHECK_ENABLED=false
OA_PKI_PATH=/hportal/Login/checkUserPKI.jsp
OA_USER_NUM_PATH=/hitem/api/getUserNum.jsp
