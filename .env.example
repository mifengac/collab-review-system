# ============================================================
# 材料协同办理系统 — 内网 Docker 部署配置
# 使用：复制为本目录 .env 后按需修改
#   cp .env.example .env
#   docker compose up -d
# 访问：http://服务器IP:5002/login.html
# ============================================================

# ---------- 服务 ----------
APP_NAME=材料协同办理系统
APP_HOST=0.0.0.0
# 宿主机映射端口（与 compose ports 左侧一致）
APP_PORT=5002
# 请修改为随机长字符串（生产必改）
SECRET_KEY=please-change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480
DEBUG=false

# ---------- 数据库 ----------
# Docker 内默认 SQLite（数据在命名卷 collab_data）
DATABASE_URL=sqlite:////app/data/collab.db
# 若内网有 PostgreSQL / 人大金仓 Kingbase，可改为（镜像含 psycopg2，并兼容金仓 version 串）：
# DATABASE_URL=postgresql://user:password@内网IP:5432/collab_review
# DATABASE_URL=postgresql://user:password@内网IP:54321/collab_review


# ---------- 管理员（仅首次建库时创建，之后改此值不会更新库中密码）----------
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_DISPLAY_NAME=系统管理员

# ---------- 演示账号 ----------
# 内网生产务必 false。true 时创建 office1/supervisor1/handler1/leader_a/leader_b（密码 Demo@123456）
SEED_DEMO_USERS=false

# ---------- 文件上传（容器内路径，对应 compose 卷 collab_uploads）----------
UPLOAD_DIR=/app/uploads

# ---------- 认证模式 ----------
# local  仅本系统账号（无外网、先验证功能时推荐）
# oa     仅 OA 账号密码登录
# mixed  优先 OA；OA 不可用时仅本地 admin 可登录维护
AUTH_MODE=local

# ---------- OA（AUTH_MODE=oa 或 mixed 时填写内网 OA 地址；勿写真实个人账号密码）----------
OA_BASE_URL=http://your-oa-host.example
OA_LOGIN_PATH=/hportal/j_security_check
OA_PROFILE_PATH=/hportal/view/GetModuleTree.do
# 登录前 GET 此路径热身，让 cookie 罐收下会话（真实 OA 需要；默认 /hportal/）
OA_WARMUP_PATH=/hportal/
OA_LOGIN_TIMEOUT_SECONDS=8
OA_DEFAULT_ROLE=viewer
OA_VERIFY_TLS=false
# 预检接口不下发 cookie，不能替代热身；多数环境保持 false
OA_PRECHECK_ENABLED=false
OA_PKI_PATH=/hportal/Login/checkUserPKI.jsp
OA_USER_NUM_PATH=/hitem/api/getUserNum.jsp

# ---------- OA 公文池同步 ----------
# 登录成功后是否自动拉取五个公文模块列表（仅本次走 OA 登录时生效）
OA_SYNC_ON_LOGIN=false
OA_SYNC_MAX_PAGES=3
# OA 列表每页通常 10 条（与真实 OA 一致）；登录同步默认最多 3 页，勿一次拉全量历史
OA_SYNC_PAGE_SIZE=10
OA_SYNC_MODULES=todo,unread,done,read_done,running
# 列表接口路径
OA_LIST_PATH=/hmoa/s
# 定时本地维护（分钟，0=关闭）。无 OA 密码，不能自动重登拉新公文，仅下线过期未关联记录
OA_SCHEDULED_SYNC_MINUTES=0
# 仅处理近 N 天有同步记录的用户
OA_SCHEDULED_SYNC_USER_DAYS=7
# 未关联事项且超过 N 天未同步的公文池记录可标 inactive
OA_STALE_DAYS=30

# ---------- 模拟 OA（仅开发预览；正式环境务必 false）----------
# true 时必须同时 DEBUG=true，否则应用拒绝启动
# 正式部署与 docker-compose.yml 默认 false
OA_MOCK_ENABLED=false

# ---------- ONLYOFFICE Document Server（默认关闭；预览/内网部署后开启）----------
# 正式 docker-compose.yml 暂不挂 DS，仅 preview 环境联调
ONLYOFFICE_ENABLED=false
# 浏览器访问 DS 的地址（加载 /web-apps/apps/api/documents/api.js）
ONLYOFFICE_PUBLIC_URL=
# 本系统容器访问 DS 的地址（可与 public 不同；多数情况与 public 相同或用服务名）
ONLYOFFICE_INTERNAL_URL=
# 与 Document Server 容器环境变量 JWT_SECRET 一致（勿提交真实生产密钥）
ONLYOFFICE_JWT_SECRET=
# DS 回访本系统的基地址（文档下载 + 保存回调），如 http://collab-preview:5002
APP_INTERNAL_URL=
