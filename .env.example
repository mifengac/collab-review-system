# 服务配置
APP_NAME=材料协同办理系统
APP_HOST=0.0.0.0
APP_PORT=5009
SECRET_KEY=please-change-this-to-a-random-secret-key
ACCESS_TOKEN_EXPIRE_MINUTES=480

# 数据库（默认 SQLite，切换 PostgreSQL/Kingbase 时改 DATABASE_URL）
# SQLite:
DATABASE_URL=sqlite:///./data/collab.db
# PostgreSQL 示例:
# DATABASE_URL=postgresql://user:password@host:5432/collab_review
# Kingbase 示例:
# DATABASE_URL=postgresql://user:password@host:54321/collab_review

# 默认管理员（首次启动自动创建，密码哈希存储）
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin@123456
ADMIN_DISPLAY_NAME=系统管理员

# 是否创建演示账号 handler1 / leader_a / leader_b（密码 Demo@123456）
# 生产环境务必保持 false；本地联调可设为 true
SEED_DEMO_USERS=false

# 文件上传目录
UPLOAD_DIR=./uploads

# 调试模式（生产环境请设为 false）
DEBUG=false
